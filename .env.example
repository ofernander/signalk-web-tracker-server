# signalk-web-tracker server configuration.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# REQUIRED. HMAC signing key shared with the boat plugin. Must match the
# "Shared Signing Key" configured in the SignalK plugin exactly. Use a long
# random string, e.g. the output of: openssl rand -hex 32
SHARED_KEY=

# Name shown as the heading in the web UI. Defaults to "SignalK-Web-Tracker".
VESSEL_NAME=

# Port the server listens on inside the container. The reverse proxy forwards
# to this. Default 8080.
PORT=8080

# Reject ingest requests whose timestamp is more than this many seconds from
# the server's clock. Guards against replay of captured requests. Default 300.
TIMESTAMP_WINDOW_SEC=300

# Ingest rate limit (defense-in-depth on top of HMAC): max requests per window
# per client IP, and the window length in seconds. Defaults 60 / 60.
INGEST_RATE_MAX=60
INGEST_RATE_WINDOW_SEC=60

# Optional override for the sqlite database path. Defaults to data/web-tracker-server.db
# DB_PATH=/app/data/web-tracker-server.db
