{
  "version": 8,
  "name": "OSM Liberty",
  "metadata": {
    "maputnik:license": "https://github.com/maputnik/osm-liberty/blob/gh-pages/LICENSE.md",
    "maputnik:renderer": "mbgljs",
    "openmaptiles:version": "3.x"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    },
    "natural_earth_shaded_relief": {
      "maxzoom": 6,
      "tileSize": 256,
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "type": "raster"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgba(253, 243, 243, 1)"
      },
      "layout": {"visibility": "visible"}
    },
    {
      "id": "natural_earth",
      "type": "raster",
      "source": "natural_earth_shaded_relief",
      "maxzoom": 6,
      "paint": {
        "raster-opacity": {
          "base": 1.5,
          "stops": [[0, 0.6], [6, 0.1]]
        }
      },
      "layout": {
        "visibility": "none"
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#d8e8c8",
        "fill-opacity": 1,
        "fill-outline-color": "rgba(95, 208, 100, 1)"
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "park_outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "line-dasharray": [1, 1.5],
        "line-color": "rgba(228, 241, 215, 1)"
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "landcover_wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "all",
        ["==", "class", "wood"]
      ],
      "paint": {
        "fill-antialias": false,
        "fill-color": "hsla(98, 61%, 72%, 0.7)",
        "fill-opacity": 1
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "landcover_grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "all",
        ["==", "class", "grass"]
      ],
      "paint": {
        "fill-antialias": false,
        "fill-color": "rgba(176, 213, 154, 1)",
        "fill-opacity": 1
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "landcover_ice",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "all",
        ["==", "class", "ice"]
      ],
      "paint": {
        "fill-antialias": false,
        "fill-color": "rgba(224, 236, 236, 1)",
        "fill-opacity": 1
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "landcover_wetland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "minzoom": 12,
      "filter": [
        "all",
        ["==", "class", "wetland"]
      ],
      "paint": {
        "fill-antialias": true,
        "fill-opacity": 1,
        "fill-pattern": "wetland_bg_11",
        "fill-translate-anchor": "map"
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["!=", "brunnel", "tunnel"]
      ],
      "paint": {
        "fill-color": "rgba(125, 208, 255, 1)"
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "landcover_sand",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "all",
        ["==", "class", "sand"]
      ],
      "paint": {
        "fill-color": "rgba(247, 239, 195, 1)"
      },
      "layout": {
        "visibility": "visible"
      }
    },
    {
      "id": "water_name_line",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "all",
        ["==", "$type", "LineString"]
      ],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 5,
        "text-size": 12,
        "symbol-placement": "line",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#5d60be",
        "text-halo-color": "rgba(255,255,255,0.7)",
        "text-halo-width": 1
      }
    },
    {
      "id": "water_name_point",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "filter": [
        "==",
        "$type",
        "Point"
      ],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 5,
        "text-size": 12,
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#5d60be",
        "text-halo-color": "rgba(255,255,255,0.7)",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_other",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        [
          "in",
          "class",
          "hamlet",
          "island",
          "islet",
          "neighbourhood",
          "suburb",
          "quarter"
        ]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Italic"
        ],
        "text-letter-spacing": 0.1,
        "text-max-width": 9,
        "text-size": {
          "base": 1.2,
          "stops": [[12, 10], [15, 14]]
        },
        "text-transform": "uppercase",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#633",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1.2
      },
      "minzoom": 7
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        ["==", "class", "village"]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8,
        "text-size": {
          "base": 1.2,
          "stops": [[10, 12], [15, 22]]
        },
        "visibility": "none"
      },
      "paint": {
        "text-color": "#333",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1.2
      },
      "minzoom": 7
    },
    {
      "id": "place_town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        ["==", "class", "town"]
      ],
      "layout": {
        "icon-image": {
          "base": 1,
          "stops": [
            [0, "dot_9"],
            [8, ""]
          ]
        },
        "text-anchor": "bottom",
        "text-field": "{name_en}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8,
        "text-offset": [0, 0],
        "text-size": {
          "base": 1.2,
          "stops": [[7, 12], [11, 16]]
        },
        "visibility": "none"
      },
      "paint": {
        "text-color": "#333",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1.2
      },
      "minzoom": 7
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 5,
      "filter": [
        "all",
        ["==", "class", "city"]
      ],
      "layout": {
        "icon-image": {
          "base": 1,
          "stops": [
            [0, "dot_9"],
            [8, ""]
          ]
        },
        "text-anchor": "bottom",
        "text-field": "{name_en}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 8,
        "text-offset": [0, 0],
        "text-size": {
          "base": 0.8,
          "stops": [[7, 14], [11, 24]]
        },
        "icon-allow-overlap": true,
        "icon-optional": false,
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#333",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "state",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 6,
      "filter": [
        "all",
        ["==", "class", "state"]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Italic"
        ],
        "text-size": {
          "stops": [[4, 11], [6, 15]]
        },
        "text-transform": "uppercase",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#633",
        "text-halo-color": "rgba(255,255,255,0.7)",
        "text-halo-width": 1
      },
      "minzoom": 5
    },
    {
      "id": "country_3",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        [">=", "rank", 3],
        ["==", "class", "country"]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Italic"
        ],
        "text-max-width": 6.25,
        "text-size": {
          "stops": [[3, 11], [7, 17]]
        },
        "text-transform": "none",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#334",
        "text-halo-blur": 1,
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "country_2",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        ["==", "rank", 2],
        ["==", "class", "country"]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Italic"
        ],
        "text-max-width": 6.25,
        "text-size": {
          "stops": [[2, 11], [5, 17]]
        },
        "text-transform": "none",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#334",
        "text-halo-blur": 1,
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "country_1",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        ["==", "rank", 1],
        ["==", "class", "country"]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Italic"
        ],
        "text-max-width": 6.25,
        "text-size": {
          "stops": [[1, 11], [4, 17]]
        },
        "text-transform": "none",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#334",
        "text-halo-blur": 1,
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "continent",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 1,
      "filter": [
        "all",
        ["==", "class", "continent"]
      ],
      "layout": {
        "text-field": "{name_en}",
        "text-font": [
          "Noto Sans Italic"
        ],
        "text-size": 13,
        "text-transform": "uppercase",
        "text-justify": "center",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#633",
        "text-halo-color": "rgba(255,255,255,0.7)",
        "text-halo-width": 1
      }
    }
  ],
  "id": "osm-liberty"
}